# Database Configuration
DATABASE_URL=postgres://geouser:geopass@localhost:5432/geospatial

# Alternative database configuration (if not using DATABASE_URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geospatial
POSTGRES_USER=geouser
POSTGRES_PASSWORD=geopass

# Data file paths (replace with actual paths)
GEOJSON_LINES_PATH=/path/to/transmission-lines.geojson
CSV_GEOTHERMAL_PATH=/path/to/geothermal-data.csv

# Optional: Performance tuning
MAX_BATCH_SIZE=500000
DEFAULT_BATCH_SIZE_CSV=250000
DEFAULT_BATCH_SIZE_GEOJSON=10000
MEMORY_LIMIT_MB=1024

# Optional: Ingestion settings
RESUME_DIR=.ingest
LOG_LEVEL=info