{
  "name": "@geospatial/ingest",
  "version": "1.0.0",
  "description": "High-performance geospatial data ingestion CLI",
  "main": "dist/ingest.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/ingest.ts",
    "start": "node dist/ingest.js",
    "clean": "rm -rf dist",
    "scrape": "ts-node src/run-multi-listing-scraper.ts",
    "scrape:all": "ts-node src/run-multi-listing-scraper.ts scrape",
    "scrape:test": "ts-node src/run-multi-listing-scraper.ts test",
    "scrape:stats": "ts-node src/run-multi-listing-scraper.ts stats",
    "scrape:init": "ts-node src/run-multi-listing-scraper.ts init"
  },
  "bin": {
    "geoingest": "dist/ingest.js"
  },
  "dependencies": {
    "@turf/turf": "^6.5.0",
    "adm-zip": "^0.5.10",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^11.1.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3",
    "pg-copy-streams": "^6.0.5",
    "playwright": "^1.40.0",
    "puppeteer": "^21.5.0",
    "shapefile": "^0.6.6",
    "stream-json": "^1.8.0",
    "wellknown": "^0.5.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.0",
    "@types/cheerio": "^0.22.31",
    "@types/node": "^20.8.0",
    "@types/node-fetch": "^2.6.9",
    "@types/pg": "^8.10.7",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/stream-json": "^1.7.8",
    "@types/wellknown": "^0.5.8",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
